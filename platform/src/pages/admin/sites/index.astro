---
// platform/src/pages/admin/sites/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { parseSessionCookie } from '../../../lib/session';
import { isAdminSession } from '../../../lib/admin';
import { apiClient } from '../../../lib/api-client';

const session = parseSessionCookie(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/auth/login');
if (!isAdminSession(session)) return Astro.redirect('/dashboard');
Astro.locals.user = { id: session.userId, email: session.email, username: session.username, avatar_url: session.avatarUrl };

interface AdminSite { id: string; user_id: string; site_name: string; domain: string; status: string; worker_id: string | null; created_at: number; }
const sitesResult = await apiClient.get<AdminSite[]>('/api/admin/sites?limit=100', Astro.request.headers.get('cookie'));
const sites = sitesResult.success ? sitesResult.data : [];

const statusBadgeClass: Record<string, string> = {
  active: 'badge-success',
  provisioning: 'badge-warning',
  suspended: 'badge-caution',
  deleted: 'badge-danger',
};
---
<AdminLayout title="사이트 관리" activeNav="sites">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white mb-2">전체 사이트</h1>
    <p class="text-surface-400">플랫폼에 등록된 모든 사용자의 호스팅 현황입니다. 전체 {sites.length}건.</p>
  </div>

  <div class="glass rounded-xl overflow-hidden overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-surface-800">
        <tr>
          <th class="text-left p-4 text-surface-400">사이트명</th>
          <th class="text-left p-4 text-surface-400">도메인</th>
          <th class="text-left p-4 text-surface-400">상태</th>
          <th class="text-left p-4 text-surface-400">Worker</th>
          <th class="text-left p-4 text-surface-400">생성일</th>
        </tr>
      </thead>
      <tbody>
        {sites.map((s) => (
          <tr class="border-t border-surface-800">
            <td class="p-4 font-medium text-white">{s.site_name}</td>
            <td class="p-4 text-surface-400">{s.domain}</td>
            <td class="p-4"><span class:list={['badge', statusBadgeClass[s.status] || 'badge-neutral']}>{s.status}</span></td>
            <td class="p-4 text-surface-400 font-mono text-xs">{s.worker_id || '—'}</td>
            <td class="p-4 text-surface-400">{new Date(s.created_at * 1000).toLocaleDateString('ko-KR')}</td>
          </tr>
        ))}
      </tbody>
    </table>
    {sites.length === 0 && <div class="p-10 text-center text-surface-500">등록된 사이트가 없습니다.</div>}
  </div>
</AdminLayout>
