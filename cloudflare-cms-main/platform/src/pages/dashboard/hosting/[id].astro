---
// platform/src/pages/dashboard/hosting/[id].astro
import DashboardLayout from '@layouts/DashboardLayout.astro';
import { parseSessionCookie } from '@lib/session';
import { apiClient } from '@lib/api-client';
import type { Site } from '@shared/types/site';

const session = parseSessionCookie(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/auth/login');
Astro.locals.user = { id: session.userId, email: session.email, username: session.username, avatar_url: session.avatarUrl };

const { id } = Astro.params;
const siteResult = await apiClient.get<Site>(`/api/sites/${id}`, Astro.request.headers.get('cookie'));

if (!siteResult.success || !siteResult.data) {
  return Astro.redirect('/dashboard/hosting?error=not_found');
}

const site = siteResult.data;

// Hosting metrics (would come from Cloudflare Analytics Engine)
const hostingMetrics = {
  storageUsedGB: 2.5,
  storageQuotaGB: -1, // unlimited
  dbSizeGB: 1.2,
  requestsPerSecond: 125,
  requestsPerMinute: 7500,
  requestsPerHour: 450000,
  requestsPerDay: 10800000,
  cacheHitRate: 85.5,
  avgResponseTime: 45,
};

// Mock WordPress sites (would come from database)
const wordPressSites = [
  {
    id: 'wp-001',
    title: site.site_name,
    domain: site.domain,
    postsCount: 42,
    pagesCount: 8,
    usersCount: 3,
    dbSizeGB: 1.2,
    phpVersion: '8.3',
    theme: 'Twenty Twenty-Four',
    pluginCount: 5,
    cacheHitRate: 87.3,
    status: 'active',
  },
];
---
<DashboardLayout title={`${site.site_name} - 호스팅 상세`} activeNav="hosting">
  <div class="mb-8">
    <a href="/dashboard/hosting" class="text-sm text-surface-500 hover:text-surface-300 mb-3 inline-flex items-center gap-1">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"/></svg>
      호스팅 관리
    </a>
    <h1 class="text-3xl font-bold text-white">{site.site_name} 호스팅</h1>
    <p class="text-surface-400 mt-1">모든 WordPress 인스턴스 및 리소스 상태</p>
  </div>

  <!-- 호스팅 통계 -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="glass rounded-2xl p-6">
      <p class="text-xs text-surface-500 font-semibold mb-2">스토리지 사용량</p>
      <p class="text-3xl font-bold text-white mb-1">{hostingMetrics.storageUsedGB}GB</p>
      <p class="text-xs text-surface-400">무제한</p>
    </div>
    <div class="glass rounded-2xl p-6">
      <p class="text-xs text-surface-500 font-semibold mb-2">데이터베이스 크기</p>
      <p class="text-3xl font-bold text-white mb-1">{hostingMetrics.dbSizeGB}GB</p>
      <p class="text-xs text-surface-400">무제한</p>
    </div>
    <div class="glass rounded-2xl p-6">
      <p class="text-xs text-surface-500 font-semibold mb-2">캐시 히트율</p>
      <p class="text-3xl font-bold text-white mb-1">{hostingMetrics.cacheHitRate}%</p>
      <p class="text-xs text-surface-400">WP-Rocket + Cloudflare</p>
    </div>
    <div class="glass rounded-2xl p-6">
      <p class="text-xs text-surface-500 font-semibold mb-2">평균 응답시간</p>
      <p class="text-3xl font-bold text-white mb-1">{hostingMetrics.avgResponseTime}ms</p>
      <p class="text-xs text-surface-400">WASM 기준</p>
    </div>
  </div>

  <!-- 요청 통계 -->
  <div class="glass rounded-2xl p-6 mb-8">
    <h2 class="text-lg font-semibold text-white mb-4">요청/호출 통계</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="p-4 bg-surface-800/50 rounded-lg border border-surface-700">
        <p class="text-xs text-surface-500 mb-1">초당 요청</p>
        <p class="text-xl font-bold text-white">{hostingMetrics.requestsPerSecond}/초</p>
      </div>
      <div class="p-4 bg-surface-800/50 rounded-lg border border-surface-700">
        <p class="text-xs text-surface-500 mb-1">분당 요청</p>
        <p class="text-xl font-bold text-white">{hostingMetrics.requestsPerMinute.toLocaleString()}/분</p>
      </div>
      <div class="p-4 bg-surface-800/50 rounded-lg border border-surface-700">
        <p class="text-xs text-surface-500 mb-1">시간당 요청</p>
        <p class="text-xl font-bold text-white">{(hostingMetrics.requestsPerHour / 1000).toFixed(1)}K/시간</p>
      </div>
      <div class="p-4 bg-surface-800/50 rounded-lg border border-surface-700">
        <p class="text-xs text-surface-500 mb-1">일일 요청</p>
        <p class="text-xl font-bold text-white">{(hostingMetrics.requestsPerDay / 1000000).toFixed(2)}M/일</p>
      </div>
    </div>
  </div>

  <!-- WordPress 인스턴스 카드 -->
  <section class="mb-8">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-semibold text-white">WordPress 인스턴스</h2>
      <a href="/dashboard/sites/create" class="btn-primary text-sm">새 인스턴스 추가</a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {wordPressSites.map((wp) => (
        <a href={`/dashboard/wordpress/${wp.id}`} class="group glass rounded-2xl p-6 hover:border-brand-500/50 transition-all hover:scale-[1.02] cursor-pointer">
          <div class="flex items-start justify-between mb-4">
            <div className="flex-1">
              <h3 class="text-lg font-semibold text-white group-hover:text-brand-400 transition-colors">{wp.title}</h3>
              <p class="text-sm text-surface-400">{wp.domain}</p>
            </div>
            <span class="px-2 py-1 bg-green-500/10 text-green-400 text-xs font-semibold rounded-full">{wp.status}</span>
          </div>
          
          <div class="space-y-3 mb-4 pb-4 border-b border-surface-700">
            <div class="flex justify-between text-sm">
              <span class="text-surface-500">PHP 버전</span>
              <span class="text-white font-medium">{wp.phpVersion}</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-surface-500">DB 크기</span>
              <span class="text-white font-medium">{wp.dbSizeGB}GB</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-surface-500">캐시 히트율</span>
              <span class="text-white font-medium">{wp.cacheHitRate}%</span>
            </div>
          </div>
          
          <div class="grid grid-cols-3 gap-3 text-xs text-center">
            <div class="bg-surface-800/50 rounded-lg p-2">
              <p class="text-surface-500 mb-1">게시물</p>
              <p class="text-lg font-bold text-white">{wp.postsCount}</p>
            </div>
            <div class="bg-surface-800/50 rounded-lg p-2">
              <p class="text-surface-500 mb-1">페이지</p>
              <p class="text-lg font-bold text-white">{wp.pagesCount}</p>
            </div>
            <div class="bg-surface-800/50 rounded-lg p-2">
              <p class="text-surface-500 mb-1">사용자</p>
              <p class="text-lg font-bold text-white">{wp.usersCount}</p>
            </div>
          </div>
          
          <div class="mt-4 flex items-center gap-2 text-surface-400 group-hover:text-brand-400 transition-colors text-sm">
            상세 보기
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <a class="btn-secondary text-sm justify-center" href="/dashboard/domains">도메인 관리</a>
    <a class="btn-secondary text-sm justify-center" href="/dashboard/cdn">CDN 캐시 관리</a>
    <a class="btn-secondary text-sm justify-center" href="/dashboard/migration">마이그레이션</a>
  </section>

  <section class="glass rounded-2xl p-6 border border-red-500/20">
    <h2 class="text-lg font-semibold text-red-400 mb-2">위험 구역</h2>
    <p class="text-sm text-surface-400 mb-4">호스팅을 삭제하면 모든 WordPress 인스턴스가 제거되고 도메인 라우팅이 해제됩니다. 이 작업은 되돌릴 수 없습니다.</p>
    <button id="delete-hosting-btn" data-site-id={site.id} class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-red-500/10 text-red-400 font-medium rounded-lg border border-red-500/30 hover:bg-red-500/20 transition-colors">
      호스팅 삭제
    </button>
    <div id="delete-error" class="hidden mt-3 p-3 rounded-lg bg-red-500/10 border border-red-500/30 text-sm text-red-400"></div>
  </section>
</DashboardLayout>
<script>
  const btn = document.getElementById('delete-hosting-btn') as HTMLButtonElement | null;
  const errorEl = document.getElementById('delete-error') as HTMLDivElement | null;
  btn?.addEventListener('click', async () => {
    const siteId = btn.dataset.siteId;
    if (!siteId) return;
    const confirmed = window.confirm('정말로 이 호스팅을 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다.');
    if (!confirmed) return;
    btn.disabled = true;
    btn.textContent = '삭제 중...';
    errorEl?.classList.add('hidden');
    try {
      const r = await fetch(`/api/sites/${siteId}`, { method: 'DELETE' });
      const result = await r.json();
      if (result.success) {
        window.location.href = '/dashboard/sites';
      } else {
        if (errorEl) { errorEl.textContent = result.error?.message || '삭제에 실패했습니다.'; errorEl.classList.remove('hidden'); }
        btn.disabled = false;
        btn.textContent = '호스팅 삭제';
      }
    } catch {
      if (errorEl) { errorEl.textContent = '네트워크 오류가 발생했습니다.'; errorEl.classList.remove('hidden'); }
      btn.disabled = false;
      btn.textContent = '호스팅 삭제';
    }
  });
</script>
