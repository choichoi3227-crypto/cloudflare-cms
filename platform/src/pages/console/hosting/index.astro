---
// 호스팅 목록 페이지
// 경로: /console/hosting
import ConsoleLayout from '@layouts/ConsoleLayout.astro';

// 데모 호스팅 데이터
const hostings = [
  {
    id: 1,
    name: '블로그 호스팅',
    domain: 'blog.example.com',
    status: 'active',
    storage: 12.5,
    traffic: 2450,
    sites: 1,
    createdAt: '2026-06-15',
  },
  {
    id: 2,
    name: '포트폴리오 호스팅',
    domain: 'portfolio.example.com',
    status: 'active',
    storage: 8.3,
    traffic: 1200,
    sites: 1,
    createdAt: '2026-05-20',
  },
  {
    id: 3,
    name: '회사 웹사이트',
    domain: 'company.example.com',
    status: 'active',
    storage: 25.8,
    traffic: 5670,
    sites: 3,
    createdAt: '2026-04-10',
  },
  {
    id: 4,
    name: 'E-커머스 호스팅',
    domain: 'shop.example.com',
    status: 'active',
    storage: 45.2,
    traffic: 8900,
    sites: 2,
    createdAt: '2026-03-05',
  },
  {
    id: 5,
    name: '테스트 호스팅',
    domain: 'test.example.com',
    status: 'suspended',
    storage: 2.1,
    traffic: 100,
    sites: 1,
    createdAt: '2026-01-01',
  },
];

const getStatusBadge = (status: string) => {
  if (status === 'active') {
    return {
      color: 'bg-success-100 text-success-700',
      label: '활성',
    };
  }
  if (status === 'suspended') {
    return {
      color: 'bg-warning-100 text-warning-700',
      label: '중지됨',
    };
  }
  return {
    color: 'bg-surface-100 text-surface-700',
    label: '상태 불명',
  };
};
---

<ConsoleLayout>
  <div class="p-8 space-y-8">
    <!-- 헤더 -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-surface-900 mb-2">호스팅 관리</h1>
        <p class="text-surface-600">모든 WordPress 호스팅을 관리하세요</p>
      </div>
      <button class="flex items-center space-x-2 bg-primary-500 hover:bg-primary-600 text-white font-semibold py-3 px-6 rounded-lg transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
        </svg>
        <span>새 호스팅 생성</span>
      </button>
    </div>

    <!-- 호스팅 카드 그리드 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {hostings.map((hosting) => {
        const statusBadge = getStatusBadge(hosting.status);
        return (
          <div class="group bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-all hover:scale-105">
            {/* 헤더 */}
            <div class="bg-gradient-to-r from-primary-500 to-primary-600 p-6 text-white">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h3 class="text-lg font-bold">{hosting.name}</h3>
                  <p class="text-primary-100 text-sm">{hosting.domain}</p>
                </div>
                <span class={`px-3 py-1 rounded-full text-xs font-semibold ${statusBadge.color}`}>
                  {statusBadge.label}
                </span>
              </div>
            </div>

            {/* 메트릭 */}
            <div class="p-6 space-y-4">
              {/* 스토리지 */}
              <div>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-semibold text-surface-700">스토리지</span>
                  <span class="text-sm font-bold text-surface-900">{hosting.storage.toFixed(1)} GB</span>
                </div>
                <div class="w-full bg-surface-200 rounded-full h-2">
                  <div class="bg-primary-500 h-2 rounded-full" style={`width: ${(hosting.storage / 100) * 100}%`}></div>
                </div>
              </div>

              {/* 트래픽 */}
              <div>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-semibold text-surface-700">이번 달 트래픽</span>
                  <span class="text-sm font-bold text-surface-900">{hosting.traffic.toLocaleString()}</span>
                </div>
                <div class="w-full bg-surface-200 rounded-full h-2">
                  <div class="bg-success-500 h-2 rounded-full" style={`width: ${(hosting.traffic / 10000) * 100}%`}></div>
                </div>
              </div>

              {/* 세부 정보 */}
              <div class="grid grid-cols-2 gap-3 pt-4 border-t border-surface-200">
                <div>
                  <p class="text-xs text-surface-500">사이트 수</p>
                  <p class="text-lg font-bold text-surface-900">{hosting.sites}</p>
                </div>
                <div>
                  <p class="text-xs text-surface-500">생성일</p>
                  <p class="text-sm font-semibold text-surface-900">{hosting.createdAt}</p>
                </div>
              </div>
            </div>

            {/* 액션 */}
            <div class="px-6 py-4 bg-surface-50 border-t border-surface-200 flex items-center justify-between">
              <a href={`/dashboard/hosting/${hosting.id}`} class="text-primary-600 hover:text-primary-700 font-semibold text-sm flex items-center space-x-1">
                <span>상세보기</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
              <button class="text-surface-600 hover:text-surface-700 transition-colors p-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                </svg>
              </button>
            </div>
          </div>
        );
      })}
    </div>

    {/* 빈 상태 메시지 (호스팅이 없을 때) */}
    {hostings.length === 0 && (
      <div class="bg-white rounded-xl shadow-md p-16 text-center">
        <svg class="w-16 h-16 text-surface-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
        </svg>
        <h3 class="text-xl font-bold text-surface-900 mb-2">호스팅이 없습니다</h3>
        <p class="text-surface-600 mb-6">새로운 WordPress 호스팅을 생성하여 시작하세요</p>
        <button class="inline-flex items-center space-x-2 bg-primary-500 hover:bg-primary-600 text-white font-semibold py-3 px-6 rounded-lg transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
          </svg>
          <span>지금 시작하기</span>
        </button>
      </div>
    )}
  </div>
</ConsoleLayout>
