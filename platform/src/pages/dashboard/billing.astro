---
// platform/src/pages/dashboard/billing.astro
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { parseSessionCookie } from '../../lib/session';
import { apiClient } from '../../lib/api-client';
import { PLAN_DEFINITIONS, COMMON_PLAN_FEATURES } from '../../lib/plan-policy';

const session = parseSessionCookie(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/auth/login');
Astro.locals.user = { id: session.userId, email: session.email, username: session.username, avatar_url: session.avatarUrl };

const sitesResult = await apiClient.get<Array<{ id: string; status: string }>>('/api/sites', Astro.request.headers.get('cookie'));
const activeSiteCount = sitesResult.success ? (sitesResult.data ?? []).filter((s) => s.status === 'active').length : 0;
---
<DashboardLayout title="결제 및 요금제" activeNav="settings">
  <div class="mb-8"><h1 class="text-2xl font-bold text-white mb-2">결제 및 요금제</h1><p class="text-surface-400">CloudPress는 호스팅 단위 월 결제만 적용합니다. 계정 단위 과금은 없습니다.</p></div>

  <div class="glass rounded-xl p-6 mb-8 flex items-center justify-between flex-wrap gap-4">
    <div>
      <p class="text-sm text-surface-500 mb-1">현재 생성된 사이트</p>
      <p class="text-2xl font-bold text-white">{activeSiteCount}개</p>
    </div>
    <a class="btn-primary" href="/products">새 호스팅 플랜 결제하기</a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 mb-8">
    {PLAN_DEFINITIONS.map((plan) => (
      <div class="glass rounded-xl p-6 relative border border-surface-800">
        <h2 class="text-lg font-semibold text-white mb-1">{plan.name}</h2>
        <p class="text-sm text-surface-500 mb-4">호스팅 1개 · 월 결제</p>
        <p class="mb-4"><span class="text-3xl font-bold text-white">₩{plan.monthlyKRW.toLocaleString('ko-KR')}</span><span class="text-sm text-surface-500">/월</span></p>
        <p class="text-sm text-brand-300 mb-4">{plan.loadBalancingDescription}</p>
        <ul class="space-y-2 mb-6">
          {COMMON_PLAN_FEATURES.slice(0, 6).map((f) => (
            <li class="flex items-start gap-2 text-sm text-surface-400"><svg class="w-4 h-4 text-brand-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>{f}</li>
          ))}
        </ul>
        <a class="btn-primary w-full text-center" href="/products">결제하기</a>
      </div>
    ))}
  </div>

  <section class="glass rounded-xl p-6">
    <h2 class="text-lg font-semibold text-white mb-4">결제 수단</h2>
    <p class="text-sm text-surface-400 mb-4">PayPal만 지원합니다. PayPal Client ID/Secret 및 운영 환경은 어드민 설정에서 관리합니다.</p>
    <a class="btn-secondary text-sm" href="/admin/settings">PayPal 설정 관리</a>
  </section>
</DashboardLayout>
