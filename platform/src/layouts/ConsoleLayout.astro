---
// ConsoleLayout.astro - 콘솔 레이아웃 (대시보드, 사이드바)
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="flex min-h-screen bg-surface-50">
    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-surface-200 fixed h-full overflow-y-auto shadow-light-md">
      <div class="p-6 border-b border-surface-200">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white font-bold text-lg">
            W
          </div>
          <div>
            <p class="font-bold text-surface-900">콘솔</p>
            <p class="text-xs text-surface-500">WordPress Hosting</p>
          </div>
        </div>
      </div>

      <nav class="p-6 space-y-2">
        <a href="/console" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-primary-50 text-surface-700 hover:text-primary-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-3m0 0l7-4 7 4M5 9v10a1 1 0 001 1h12a1 1 0 001-1V9m-9 16l4-4m0 0l4 4m-4-4v4" />
          </svg>
          <span>대시보드</span>
        </a>

        <a href="/console/hosting" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-primary-50 text-surface-700 hover:text-primary-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
          </svg>
          <span>호스팅</span>
        </a>

        <a href="/console/domains" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-primary-50 text-surface-700 hover:text-primary-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
          <span>도메인</span>
        </a>

        <a href="/console/storage" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-primary-50 text-surface-700 hover:text-primary-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10a2 2 0 002 2h12a2 2 0 002-2V7m-4-4h8a2 2 0 012 2v2H2V5a2 2 0 012-2h8z" />
          </svg>
          <span>스토리지</span>
        </a>

        <hr class="my-4 border-surface-200" />

        <a href="/console/settings" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-primary-50 text-surface-700 hover:text-primary-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>설정</span>
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="ml-64 flex-1">
      <!-- Top Bar -->
      <div class="bg-white border-b border-surface-200 shadow-light-md sticky top-0 z-40">
        <div class="px-8 py-4 flex justify-between items-center">
          <h1 class="text-2xl font-bold text-surface-900"><slot name="title" /></h1>
          <div class="flex items-center space-x-4">
            <button class="p-2 hover:bg-surface-100 rounded-lg transition-colors">
              <svg class="w-5 h-5 text-surface-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </button>
            <button class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 text-white flex items-center justify-center font-bold">
              U
            </button>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="p-8">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  aside::-webkit-scrollbar {
    width: 6px;
  }

  aside::-webkit-scrollbar-track {
    background: transparent;
  }

  aside::-webkit-scrollbar-thumb {
    background: #d1d5db;
    border-radius: 3px;
  }

  aside::-webkit-scrollbar-thumb:hover {
    background: #9ca3af;
  }
</style>
