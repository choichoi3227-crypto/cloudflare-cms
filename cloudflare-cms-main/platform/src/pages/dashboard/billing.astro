---
// platform/src/pages/dashboard/billing.astro
import DashboardLayout from '@layouts/DashboardLayout.astro';
import { parseSessionCookie } from '@lib/session';
import { apiClient } from '@lib/api-client';

const session = parseSessionCookie(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/auth/login');
Astro.locals.user = { id: session.userId, email: session.email, username: session.username, avatar_url: session.avatarUrl };

const sitesResult = await apiClient.get<Array<{ id: string; status: string }>>('/api/sites', Astro.request.headers.get('cookie'));
const activeSiteCount = sitesResult.success ? sitesResult.data.filter((s) => s.status === 'active').length : 0;

const plans = [
  { name: 'Free', price: '₩0', period: '/월', sites: '1개 사이트', features: ['1개 WordPress 사이트', '기본 CDN', '커뮤니티 지원'], current: activeSiteCount <= 1 },
  { name: 'Pro', price: '₩19,900', period: '/월', sites: '10개 사이트', features: ['최대 10개 WordPress 사이트', '우선 CDN 캐시', 'AI 콘텐츠 생성 월 200회', '이메일 지원'], current: false, highlighted: true },
  { name: 'Business', price: '문의', period: '', sites: '무제한', features: ['사이트 수 무제한', '전용 Shard 배정', 'AI 콘텐츠 생성 무제한', '우선 지원 및 SLA'], current: false },
];
---
<DashboardLayout title="결제 및 요금제" activeNav="settings">
  <div class="mb-8"><h1 class="text-2xl font-bold text-white mb-2">결제 및 요금제</h1><p class="text-surface-400">현재 요금제를 확인하고 필요에 따라 업그레이드하세요.</p></div>

  <div class="glass rounded-xl p-6 mb-8 flex items-center justify-between flex-wrap gap-4">
    <div>
      <p class="text-sm text-surface-500 mb-1">현재 사용 중인 사이트</p>
      <p class="text-2xl font-bold text-white">{activeSiteCount}개</p>
    </div>
    <div class="text-sm text-surface-400">결제 수단이 등록되어 있지 않습니다. 요금제를 업그레이드하면 결제 수단 등록을 안내드립니다.</div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    {plans.map((plan) => (
      <div class:list={['glass rounded-xl p-6 relative', plan.highlighted && 'border-2 border-brand-500']}>
        {plan.highlighted && <span class="absolute -top-3 left-6 px-3 py-1 bg-brand-500 text-white text-xs font-medium rounded-full">추천</span>}
        <h2 class="text-lg font-semibold text-white mb-1">{plan.name}</h2>
        <p class="text-sm text-surface-500 mb-4">{plan.sites}</p>
        <p class="mb-4"><span class="text-3xl font-bold text-white">{plan.price}</span><span class="text-sm text-surface-500">{plan.period}</span></p>
        <ul class="space-y-2 mb-6">
          {plan.features.map((f) => (
            <li class="flex items-start gap-2 text-sm text-surface-400">
              <svg class="w-4 h-4 text-brand-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              {f}
            </li>
          ))}
        </ul>
        {plan.current ? (
          <button class="btn-secondary w-full" disabled>현재 요금제</button>
        ) : (
          <button class="btn-primary w-full plan-select-btn" data-plan={plan.name}>{plan.name === 'Business' ? '문의하기' : '업그레이드'}</button>
        )}
      </div>
    ))}
  </div>

  <section class="glass rounded-xl p-6">
    <h2 class="text-lg font-semibold text-white mb-4">결제 수단</h2>
    <p class="text-sm text-surface-400 mb-4">신용카드 및 PayPal 결제를 지원할 예정입니다. 현재는 Free 요금제로만 이용 가능합니다.</p>
    <div class="flex gap-3">
      <button class="btn-secondary text-sm" disabled>카드 등록 (준비 중)</button>
      <button class="btn-secondary text-sm" disabled>PayPal 연결 (준비 중)</button>
    </div>
  </section>

  <div id="plan-toast" class="hidden fixed bottom-6 right-6 glass rounded-lg px-4 py-3 text-sm text-surface-200"></div>
</DashboardLayout>
<script>
  const toast = document.getElementById('plan-toast');
  document.querySelectorAll<HTMLButtonElement>('.plan-select-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!toast) return;
      toast.textContent = `${btn.dataset.plan} 요금제 결제 기능은 준비 중입니다. 곧 만나보실 수 있어요.`;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 3000);
    });
  });
</script>
