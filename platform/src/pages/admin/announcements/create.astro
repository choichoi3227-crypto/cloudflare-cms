---
// 공지사항 작성 페이지
// 경로: /admin/announcements/create
import AdminConsoleLayout from '@layouts/AdminConsoleLayout.astro';
---

<AdminConsoleLayout>
  <div class="p-8 space-y-8">
    <!-- 헤더 -->
    <div>
      <h1 class="text-3xl font-bold text-surface-900 mb-2">공지사항 작성</h1>
      <p class="text-surface-600">새로운 공지사항을 작성하세요</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      {/* 에디터 */}
      <div class="lg:col-span-3">
        <div class="bg-white rounded-xl shadow-md p-8 space-y-6">
          <form id="announcement-form" class="space-y-6">
            {/* 제목 */}
            <div>
              <label class="block text-sm font-semibold text-surface-900 mb-3">제목</label>
              <input
                type="text"
                placeholder="공지사항 제목을 입력하세요"
                class="w-full text-2xl font-bold bg-surface-50 border border-surface-200 rounded-lg p-4 text-surface-900 placeholder-surface-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none"
                required
              />
            </div>

            {/* 요약 */}
            <div>
              <label class="block text-sm font-semibold text-surface-900 mb-3">요약</label>
              <textarea
                placeholder="공지사항 요약을 입력하세요 (선택사항)"
                rows="2"
                class="w-full bg-surface-50 border border-surface-200 rounded-lg p-4 text-surface-900 placeholder-surface-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none resize-none"
              ></textarea>
            </div>

            {/* 본문 에디터 */}
            <div>
              <label class="block text-sm font-semibold text-surface-900 mb-3">본문</label>
              
              {/* 에디터 툴바 */}
              <div class="flex items-center space-x-1 bg-surface-100 border border-surface-200 rounded-t-lg p-3 flex-wrap gap-2">
                <button type="button" class="p-2 hover:bg-surface-200 rounded transition-colors" title="굵게">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6V4zm0 12h9a5 5 0 0 1 0 10H6v-10z" />
                  </svg>
                </button>
                <button type="button" class="p-2 hover:bg-surface-200 rounded transition-colors" title="기울임">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M10 4v3h2.21l-3.42 8H6v3h8v-3h-2.21l3.42-8H18V4z" />
                  </svg>
                </button>
                <button type="button" class="p-2 hover:bg-surface-200 rounded transition-colors" title="밑줄">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M6 3v7a6 6 0 0 0 6 6 6 6 0 0 0 6-6V3m-1 16h8m-14 0h14" />
                  </svg>
                </button>
                <div class="border-r border-surface-300 h-6"></div>
                <button type="button" class="p-2 hover:bg-surface-200 rounded transition-colors" title="링크">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" />
                  </svg>
                </button>
              </div>

              {/* 에디터 */}
              <textarea
                id="content-editor"
                placeholder="공지사항 본문을 입력하세요&#10;# 마크다운을 지원합니다&#10;- 리스트&#10;- 항목"
                rows="15"
                class="w-full bg-white border border-surface-200 rounded-b-lg p-4 text-surface-900 placeholder-surface-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none resize-none font-mono"
                required
              ></textarea>
            </div>

            {/* 태그 */}
            <div>
              <label class="block text-sm font-semibold text-surface-900 mb-3">태그</label>
              <input
                type="text"
                placeholder="태그를 입력하고 Enter를 누르세요"
                class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3 text-surface-900 placeholder-surface-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none"
              />
              <div class="flex flex-wrap gap-2 mt-3">
                <span class="px-3 py-1 bg-primary-100 text-primary-700 rounded-full text-sm font-semibold flex items-center space-x-2">
                  <span>업데이트</span>
                  <button type="button" class="hover:text-primary-800">×</button>
                </span>
                <span class="px-3 py-1 bg-primary-100 text-primary-700 rounded-full text-sm font-semibold flex items-center space-x-2">
                  <span>신기능</span>
                  <button type="button" class="hover:text-primary-800">×</button>
                </span>
              </div>
            </div>
          </form>
        </div>
      </div>

      {/* 사이드바 */}
      <div class="space-y-6">
        {/* 발행 설정 */}
        <div class="bg-white rounded-xl shadow-md p-6">
          <h3 class="text-lg font-bold text-surface-900 mb-4 pb-3 border-b border-surface-200">발행</h3>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-surface-900 mb-2">상태</label>
              <select class="w-full bg-surface-50 border border-surface-200 rounded-lg p-2 text-sm text-surface-900 focus:border-primary-500 outline-none">
                <option>임시저장</option>
                <option>발행</option>
                <option>스케줄</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-semibold text-surface-900 mb-2">우선순위</label>
              <div class="space-y-2">
                {['critical', 'high', 'normal', 'low'].map((priority) => (
                  <label class="flex items-center space-x-2">
                    <input type="radio" name="priority" value={priority} />
                    <span class="text-sm text-surface-700">
                      {priority === 'critical' ? '🔴 긴급' :
                       priority === 'high' ? '🟠 중요' :
                       priority === 'normal' ? '🔵 일반' :
                       '⚪ 낮음'}
                    </span>
                  </label>
                ))}
              </div>
            </div>

            <button
              type="submit"
              form="announcement-form"
              class="w-full bg-primary-500 hover:bg-primary-600 text-white font-semibold py-3 px-4 rounded-lg transition-colors"
            >
              발행
            </button>
            <button
              type="button"
              class="w-full bg-surface-100 hover:bg-surface-200 text-surface-700 font-semibold py-3 px-4 rounded-lg transition-colors"
            >
              임시저장
            </button>
          </div>
        </div>

        {/* 카테고리 */}
        <div class="bg-white rounded-xl shadow-md p-6">
          <h3 class="text-lg font-bold text-surface-900 mb-4 pb-3 border-b border-surface-200">카테고리</h3>
          
          <div class="space-y-2">
            {['notice', 'update', 'maintenance', 'security', 'other'].map((category) => (
              <label class="flex items-center space-x-2">
                <input type="radio" name="category" value={category} required />
                <span class="text-sm text-surface-700">
                  {category === 'notice' ? '공지' :
                   category === 'update' ? '업데이트' :
                   category === 'maintenance' ? '점검' :
                   category === 'security' ? '보안' :
                   '기타'}
                </span>
              </label>
            ))}
          </div>
        </div>

        {/* 도움말 */}
        <div class="bg-info-50 rounded-xl shadow-md p-6 border-l-4 border-info-500">
          <h3 class="text-sm font-bold text-info-900 mb-2">💡 팁</h3>
          <p class="text-xs text-info-800">
            마크다운 형식을 사용하여 본문을 작성할 수 있습니다. 제목, 리스트, 링크 등을 쉽게 추가할 수 있습니다.
          </p>
        </div>
      </div>
    </div>
  </div>
</AdminConsoleLayout>

<script>
  const form = document.getElementById('announcement-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('공지사항이 저장되었습니다!');
  });
</script>
