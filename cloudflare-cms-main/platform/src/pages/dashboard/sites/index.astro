---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import { parseSessionCookie } from '@lib/session';
import { apiClient } from '@lib/api-client';
const session = parseSessionCookie(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/auth/login');
Astro.locals.user = { id: session.userId, email: session.email, username: session.username, avatar_url: session.avatarUrl };
const sitesResult = await apiClient.get<Array<{ id: string; site_name: string; domain: string; status: string; created_at: number }>>('/api/sites', Astro.request.headers.get('cookie'));
const sites = sitesResult.success ? sitesResult.data : [];
---
<DashboardLayout title="내 사이트" activeNav="sites">
  <div class="flex items-center justify-between mb-8"><div><h1 class="text-2xl font-bold text-white mb-2">내 WordPress 사이트</h1><p class="text-surface-400">단일 Worker 위에 연결된 WordPress 설치를 관리합니다.</p></div><a href="/dashboard/sites/create" class="btn-primary text-sm">사이트 만들기</a></div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">{sites.map((site) => <article class="glass rounded-xl p-6"><div class="flex items-start justify-between gap-4"><div><h2 class="text-lg font-semibold text-white">{site.site_name}</h2><p class="text-sm text-surface-400">{site.domain}</p></div><span class="text-xs text-surface-400">{site.status}</span></div><div class="mt-5 flex gap-2"><a class="btn-secondary text-xs" href={`https://${site.domain}/wp-admin/`}>WordPress 관리자</a><a class="btn-secondary text-xs" href={`/dashboard/hosting/${site.id}`}>호스팅 상세</a></div></article>)}</div>
  {sites.length === 0 && <div class="glass rounded-xl p-10 text-center"><p class="text-surface-400 mb-4">아직 생성된 WordPress 사이트가 없습니다.</p><a href="/dashboard/sites/create" class="btn-primary text-sm">첫 사이트 만들기</a></div>}
</DashboardLayout>
