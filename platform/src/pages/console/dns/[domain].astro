---
// DNS 레코드 관리 페이지
// 경로: /console/dns/[domain]
import ConsoleLayout from '@layouts/ConsoleLayout.astro';

const { domain } = Astro.params;

// 데모 DNS 레코드
const dnsRecords = [
  {
    id: 1,
    type: 'A',
    name: '@',
    content: '192.0.2.1',
    ttl: 3600,
    proxied: true,
  },
  {
    id: 2,
    type: 'CNAME',
    name: 'www',
    content: 'example.com',
    ttl: 3600,
    proxied: false,
  },
  {
    id: 3,
    type: 'MX',
    name: '@',
    content: 'mail.example.com',
    ttl: 3600,
    priority: 10,
    proxied: false,
  },
  {
    id: 4,
    type: 'TXT',
    name: '@',
    content: 'v=spf1 include:_spf.google.com ~all',
    ttl: 3600,
    proxied: false,
  },
];

const recordTypes = ['A', 'AAAA', 'CNAME', 'MX', 'TXT', 'NS'];
---

<ConsoleLayout>
  <div class="p-8 space-y-8">
    <!-- 헤더 -->
    <div>
      <h1 class="text-3xl font-bold text-surface-900 mb-2">DNS 관리 - {domain}</h1>
      <p class="text-surface-600">DNS 레코드를 추가, 수정, 삭제하세요</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {/* DNS 레코드 테이블 */}
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-md overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="bg-surface-50 border-b border-surface-200">
                  <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">타입</th>
                  <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">이름</th>
                  <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">값</th>
                  <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">TTL</th>
                  <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">프록시</th>
                  <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">작업</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-200">
                {dnsRecords.map((record) => (
                  <tr class="hover:bg-surface-50 transition-colors">
                    <td class="px-6 py-4">
                      <span class="px-2 py-1 bg-primary-100 text-primary-700 text-xs font-bold rounded">{record.type}</span>
                    </td>
                    <td class="px-6 py-4 text-sm font-semibold text-surface-900">{record.name}</td>
                    <td class="px-6 py-4">
                      <code class="text-sm text-surface-700 bg-surface-50 px-2 py-1 rounded font-mono">{record.content}</code>
                    </td>
                    <td class="px-6 py-4 text-sm text-surface-700">{record.ttl}</td>
                    <td class="px-6 py-4">
                      {record.proxied ? (
                        <span class="text-success-600 font-semibold text-sm flex items-center space-x-1">
                          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                          </svg>
                          <span>활성</span>
                        </span>
                      ) : (
                        <span class="text-surface-500 font-semibold text-sm">미활성</span>
                      )}
                    </td>
                    <td class="px-6 py-4">
                      <div class="flex items-center space-x-2">
                        <button class="text-primary-600 hover:text-primary-700 font-semibold text-sm">편집</button>
                        <button class="text-danger-600 hover:text-danger-700 font-semibold text-sm">삭제</button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      {/* DNS 레코드 추가 폼 */}
      <div>
        <div class="bg-white rounded-xl shadow-md p-6 sticky top-8">
          <h3 class="text-lg font-bold text-surface-900 mb-6">DNS 레코드 추가</h3>
          <form id="add-dns-form" class="space-y-4">
            {/* 레코드 타입 */}
            <div>
              <label class="block text-sm font-semibold text-surface-900 mb-2">타입</label>
              <select class="w-full bg-surface-50 border border-surface-200 rounded-lg p-2 text-sm text-surface-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none" required>
                <option value="">선택하세요</option>
                {recordTypes.map((type) => (
                  <option value={type}>{type}</option>
                ))}
              </select>
            </div>

            {/* 이름 */}
            <div>
              <label class="block text-sm font-semibold text-surface-900 mb-2">이름</label>
              <input
                type="text"
                placeholder="예: www"
                class="w-full bg-surface-50 border border-surface-200 rounded-lg p-2 text-sm text-surface-900 placeholder-surface-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none"
              />
            </div>

            {/* 값 */}
            <div>
              <label class="block text-sm font-semibold text-surface-900 mb-2">값</label>
              <input
                type="text"
                placeholder="예: 192.0.2.1"
                class="w-full bg-surface-50 border border-surface-200 rounded-lg p-2 text-sm text-surface-900 placeholder-surface-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none"
              />
            </div>

            {/* TTL */}
            <div>
              <label class="block text-sm font-semibold text-surface-900 mb-2">TTL (초)</label>
              <input
                type="number"
                value="3600"
                class="w-full bg-surface-50 border border-surface-200 rounded-lg p-2 text-sm text-surface-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none"
              />
            </div>

            {/* 프록시 */}
            <div class="flex items-center space-x-2">
              <input
                type="checkbox"
                id="proxied"
                class="w-4 h-4 text-primary-600 rounded"
              />
              <label for="proxied" class="text-sm text-surface-700">
                Cloudflare 프록시 활성화
              </label>
            </div>

            {/* 버튼 */}
            <button
              type="submit"
              class="w-full bg-success-500 hover:bg-success-600 text-white font-semibold py-2 px-4 rounded-lg transition-colors flex items-center justify-center space-x-2 mt-6"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
              </svg>
              <span>추가</span>
            </button>
          </form>

          {/* 도움말 */}
          <div class="mt-6 pt-6 border-t border-surface-200">
            <p class="text-xs text-surface-600 font-semibold mb-3">💡 레코드 타입 설명</p>
            <ul class="text-xs text-surface-600 space-y-2">
              <li><strong>A:</strong> IPv4 주소 매핑</li>
              <li><strong>CNAME:</strong> 도메인 별칭</li>
              <li><strong>MX:</strong> 이메일 서버</li>
              <li><strong>TXT:</strong> 텍스트 레코드</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</ConsoleLayout>

<script>
  const form = document.getElementById('add-dns-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    alert('DNS 레코드가 추가되었습니다!');
  });
</script>
