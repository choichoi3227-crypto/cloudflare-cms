---
// 어드민 설정 페이지
// 경로: /admin/settings
import AdminConsoleLayout from '@layouts/AdminConsoleLayout.astro';
---

<AdminConsoleLayout>
  <div class="p-8 space-y-8">
    <div>
      <h1 class="text-3xl font-bold text-surface-900 mb-2">시스템 설정</h1>
      <p class="text-surface-600">PayPal, 소셜 로그인, GitHub Releases, 사이트 디자인을 저장 버튼 기준으로 즉시 반영합니다.</p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
      <section class="bg-white rounded-xl shadow-md p-8">
        <h2 class="text-2xl font-bold text-surface-900 mb-2">PayPal 결제</h2>
        <p class="text-sm text-surface-500 mb-6">모든 결제는 호스팅 단위 월 결제로 생성됩니다.</p>
        <form id="payment-settings-form" class="space-y-4">
          <label class="block"><span class="block text-sm font-semibold mb-2">Client ID</span><input name="clientId" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" placeholder="PayPal Client ID" /></label>
          <label class="block"><span class="block text-sm font-semibold mb-2">Client Secret</span><input name="clientSecret" type="password" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" placeholder="••••••••" /></label>
          <label class="block"><span class="block text-sm font-semibold mb-2">API Base URL</span><input name="apiBaseUrl" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" value="https://api-m.paypal.com" /></label>
          <button class="bg-primary-500 hover:bg-primary-600 text-white font-semibold py-2 px-6 rounded-lg">저장하기</button>
        </form>
      </section>

      <section class="bg-white rounded-xl shadow-md p-8">
        <h2 class="text-2xl font-bold text-surface-900 mb-2">소셜 로그인</h2>
        <p class="text-sm text-surface-500 mb-6">사용자 로그인은 Google/GitHub와 이메일-비밀번호만 지원합니다. Google 서비스 계정은 관리자 서버 작업용으로 보관합니다.</p>
        <form id="social-settings-form" class="space-y-4">
          <label class="block"><span class="block text-sm font-semibold mb-2">Google OAuth Client ID</span><input name="googleClientId" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" /></label>
          <label class="block"><span class="block text-sm font-semibold mb-2">Google OAuth Client Secret</span><input name="googleClientSecret" type="password" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" /></label>
          <label class="block"><span class="block text-sm font-semibold mb-2">Google 서비스 계정 JSON</span><textarea name="googleServiceAccountJson" rows="4" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" placeholder="관리자 서비스 계정 JSON"></textarea></label>
          <label class="block"><span class="block text-sm font-semibold mb-2">GitHub OAuth Client ID</span><input name="githubClientId" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" /></label>
          <label class="block"><span class="block text-sm font-semibold mb-2">GitHub OAuth Client Secret</span><input name="githubClientSecret" type="password" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" /></label>
          <button class="bg-primary-500 hover:bg-primary-600 text-white font-semibold py-2 px-6 rounded-lg">저장하기</button>
        </form>
      </section>

      <section class="bg-white rounded-xl shadow-md p-8">
        <h2 class="text-2xl font-bold text-surface-900 mb-2">GitHub Releases 저장소</h2>
        <p class="text-sm text-surface-500 mb-6">현재 저장 로직은 유지하고 관리자 계정/조직의 Release 저장소를 사용합니다.</p>
        <form id="github-settings-form" class="space-y-4">
          <label class="block"><span class="block text-sm font-semibold mb-2">Owner / Org</span><input name="owner" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" placeholder="cloudpress-admin" /></label>
          <label class="block"><span class="block text-sm font-semibold mb-2">Repository</span><input name="repo" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" placeholder="wordpress-releases" /></label>
          <label class="block"><span class="block text-sm font-semibold mb-2">Admin Token</span><input name="token" type="password" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" placeholder="GitHub token" /></label>
          <button class="bg-primary-500 hover:bg-primary-600 text-white font-semibold py-2 px-6 rounded-lg">저장하기</button>
        </form>
      </section>

      <section class="bg-white rounded-xl shadow-md p-8">
        <h2 class="text-2xl font-bold text-surface-900 mb-2">사이트 디자인</h2>
        <p class="text-sm text-surface-500 mb-6">레이아웃, 폰트, 이미지, 버튼, 카드 스타일은 저장하기를 눌렀을 때만 즉시 반영됩니다.</p>
        <form id="design-settings-form" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <label class="block"><span class="block text-sm font-semibold mb-2">레이아웃</span><select name="layout" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3"><option value="modern">Modern</option><option value="classic">Classic</option><option value="compact">Compact</option></select></label>
            <label class="block"><span class="block text-sm font-semibold mb-2">폰트</span><select name="fontFamily" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3"><option>Pretendard</option><option>Noto Sans KR</option><option>Inter</option></select></label>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <label class="block"><span class="block text-sm font-semibold mb-2">버튼 CSS</span><input name="buttonCss" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" value="rounded-xl px-5 py-3" /></label>
            <label class="block"><span class="block text-sm font-semibold mb-2">카드 형식</span><input name="cardStyle" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" value="glass shadow" /></label>
          </div>
          <label class="block"><span class="block text-sm font-semibold mb-2">대표 이미지 URL</span><input name="heroImageUrl" class="w-full bg-surface-50 border border-surface-200 rounded-lg p-3" placeholder="https://..." /></label>
          <button class="bg-primary-500 hover:bg-primary-600 text-white font-semibold py-2 px-6 rounded-lg">저장하기</button>
        </form>
      </section>
    </div>

    <div id="settings-toast" class="hidden fixed bottom-6 right-6 bg-surface-900 text-white rounded-lg px-4 py-3 text-sm shadow-lg"></div>
  </div>
</AdminConsoleLayout>
<script>
  const toast = document.getElementById('settings-toast') as HTMLDivElement;
  function showToast(message: string) { toast.textContent = message; toast.classList.remove('hidden'); setTimeout(() => toast.classList.add('hidden'), 2500); }
  function formValues(form: HTMLFormElement) { return Object.fromEntries(new FormData(form).entries()); }
  async function postJson(path: string, payload: unknown) {
    const response = await fetch(path, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    const result = (await response.json()) as any;
    showToast(result.success ? '저장했습니다.' : (result.error?.message || '저장 실패'));
  }
  document.getElementById('payment-settings-form')?.addEventListener('submit', (event) => { event.preventDefault(); postJson('/api/admin/settings', { paypal: formValues(event.currentTarget as HTMLFormElement) }); });
  document.getElementById('social-settings-form')?.addEventListener('submit', (event) => { event.preventDefault(); const values = formValues(event.currentTarget as HTMLFormElement); postJson('/api/admin/settings', { google: values, github: values }); });
  document.getElementById('github-settings-form')?.addEventListener('submit', (event) => { event.preventDefault(); postJson('/api/admin/settings', { githubRelease: formValues(event.currentTarget as HTMLFormElement) }); });
  document.getElementById('design-settings-form')?.addEventListener('submit', (event) => { event.preventDefault(); postJson('/api/admin/design', formValues(event.currentTarget as HTMLFormElement)); });
</script>
