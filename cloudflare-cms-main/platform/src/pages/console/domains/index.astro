---
// 도메인 관리 페이지
// 경로: /console/domains
import ConsoleLayout from '@layouts/ConsoleLayout.astro';

// 데모 도메인 데이터
const domains = [
  {
    id: 1,
    domain: 'example.com',
    status: 'verified',
    registrar: 'GoDaddy',
    expiresAt: '2027-06-15',
    dnsConfigured: true,
    hostingId: 1,
  },
  {
    id: 2,
    domain: 'blog.example.com',
    status: 'verified',
    registrar: 'Namecheap',
    expiresAt: '2028-03-20',
    dnsConfigured: true,
    hostingId: 1,
  },
  {
    id: 3,
    domain: 'shop.example.com',
    status: 'pending',
    registrar: 'Cloudflare',
    expiresAt: null,
    dnsConfigured: false,
    hostingId: 4,
  },
];

const getStatusColor = (status: string) => {
  if (status === 'verified') return 'text-success-600 bg-success-50';
  if (status === 'pending') return 'text-warning-600 bg-warning-50';
  return 'text-danger-600 bg-danger-50';
};

const getStatusLabel = (status: string) => {
  if (status === 'verified') return '확인됨';
  if (status === 'pending') return '대기중';
  return '오류';
};

const isExpiringSoon = (expiresAt: string | null) => {
  if (!expiresAt) return false;
  const expireDate = new Date(expiresAt);
  const today = new Date();
  const daysLeft = Math.floor((expireDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
  return daysLeft < 30;
};
---

<ConsoleLayout>
  <div class="p-8 space-y-8">
    <!-- 헤더 -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-surface-900 mb-2">도메인 관리</h1>
        <p class="text-surface-600">모든 도메인을 관리하고 DNS를 설정하세요</p>
      </div>
      <a href="/console/domains/add" class="flex items-center space-x-2 bg-primary-500 hover:bg-primary-600 text-white font-semibold py-3 px-6 rounded-lg transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
        </svg>
        <span>도메인 추가</span>
      </a>
    </div>

    <!-- 도메인 테이블 -->
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="bg-surface-50 border-b border-surface-200">
              <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">도메인</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">상태</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">등록자</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">만료일</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">DNS 설정</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-surface-700">작업</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-surface-200">
            {domains.map((domain) => (
              <tr class="hover:bg-surface-50 transition-colors">
                {/* 도메인명 */}
                <td class="px-6 py-4">
                  <div class="flex items-center space-x-3">
                    <svg class="w-5 h-5 text-primary-500" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                    </svg>
                    <div>
                      <p class="font-semibold text-surface-900">{domain.domain}</p>
                      <p class="text-xs text-surface-500">호스팅 #{domain.hostingId}</p>
                    </div>
                  </div>
                </td>

                {/* 상태 */}
                <td class="px-6 py-4">
                  <span class={`px-3 py-1 rounded-full text-xs font-semibold ${getStatusColor(domain.status)}`}>
                    {getStatusLabel(domain.status)}
                  </span>
                </td>

                {/* 등록자 */}
                <td class="px-6 py-4">
                  <p class="text-sm text-surface-700">{domain.registrar}</p>
                </td>

                {/* 만료일 */}
                <td class="px-6 py-4">
                  {domain.expiresAt ? (
                    <div>
                      <p class={`text-sm font-semibold ${isExpiringSoon(domain.expiresAt) ? 'text-warning-600' : 'text-surface-700'}`}>
                        {domain.expiresAt}
                      </p>
                      {isExpiringSoon(domain.expiresAt) && (
                        <p class="text-xs text-warning-600 font-semibold">⚠️ 곧 만료됨</p>
                      )}
                    </div>
                  ) : (
                    <p class="text-sm text-surface-500">-</p>
                  )}
                </td>

                {/* DNS 설정 */}
                <td class="px-6 py-4">
                  {domain.dnsConfigured ? (
                    <div class="flex items-center space-x-1 text-success-600 font-semibold">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                      </svg>
                      <span class="text-sm">구성됨</span>
                    </div>
                  ) : (
                    <div class="flex items-center space-x-1 text-surface-400 font-semibold">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                      </svg>
                      <span class="text-sm">미구성</span>
                    </div>
                  )}
                </td>

                {/* 작업 */}
                <td class="px-6 py-4">
                  <div class="flex items-center space-x-3">
                    <a href={`/console/dns/${domain.domain}`} class="text-primary-600 hover:text-primary-700 font-semibold text-sm">
                      DNS
                    </a>
                    <button class="text-surface-600 hover:text-surface-700 transition-colors">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    {/* 빈 상태 */}
    {domains.length === 0 && (
      <div class="bg-white rounded-xl shadow-md p-16 text-center">
        <svg class="w-16 h-16 text-surface-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="text-xl font-bold text-surface-900 mb-2">도메인이 없습니다</h3>
        <p class="text-surface-600 mb-6">첫 번째 도메인을 추가하여 시작하세요</p>
        <a href="/console/domains/add" class="inline-flex items-center space-x-2 bg-primary-500 hover:bg-primary-600 text-white font-semibold py-3 px-6 rounded-lg transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
          </svg>
          <span>도메인 추가</span>
        </a>
      </div>
    )}
  </div>
</ConsoleLayout>
