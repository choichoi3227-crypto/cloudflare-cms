---
// platform/src/components/landing/Features.astro
const features = [
  { icon:'brain', title:'AI 글쓰기', desc:'키워드만 입력하면 SEO 최적화된 본문, FAQ, 메타 설명까지 자동 생성합니다.' },
  { icon:'search', title:'AI SEO 엔진', desc:'실시간 SEO 점수, 키워드 밀도, 가독성, 내부 링크 추천을 자동 제공합니다.' },
  { icon:'code', title:'Schema.org 자동 생성', desc:'Article, FAQ, Breadcrumb 등 구조화 데이터를 JSON-LD로 자동 렌더링합니다.' },
  { icon:'image', title:'AI 썸네일 생성', desc:'주제에 맞는 썸네일을 AI가 자동 생성합니다. WebP, AVIF 포맷 지원.' },
  { icon:'zap', title:'Edge 렌더링', desc:'Cloudflare Edge에서 SSR 렌더링하여 LCP 2초 이하, Lighthouse 95+를 달성합니다.' },
  { icon:'shield', title:'보안 내장', desc:'CSP, XSS Protection, CSRF Protection이 기본으로 적용됩니다.' },
  { icon:'database', title:'서버리스', desc:'VPS 없이 Cloudflare Workers, D1, KV만으로 운영합니다.' },
  { icon:'palette', title:'Astro 테마', desc:'Astro 기반 테마를 업로드하고 검증 후 바로 배포할 수 있습니다.' },
  { icon:'chart', title:'내장 분석', desc:'방문자, 페이지뷰, 검색 유입, CTR 분석을 별도 도구 없이 확인합니다.' },
];
---
<section class="section-padding relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16"><h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">플러그인 없이 <span class="gradient-text">모든 게 코어 기능</span></h2><p class="text-lg text-surface-400 max-w-2xl mx-auto">WordPress처럼 플러그인을 찾고 설치하고 충돌을 해결할 필요가 없습니다.</p></div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="group gradient-border rounded-xl p-6 card-hover bg-surface-900/50">
          <div class="w-12 h-12 rounded-xl bg-brand-500/10 flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-6 h-6 text-brand-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              {f.icon === 'brain' && <><path d="M12 2a8 8 0 00-8 8c0 3.4 2.1 6.3 5 7.5V20h6v-2.5c2.9-1.2 5-4.1 5-7.5a8 8 0 00-8-8z"/><path d="M10 20v2h4v-2"/><path d="M9 8h.01M15 8h.01M10 12a2 2 0 002 2h0a2 2 0 002-2"/></>}
              {f.icon === 'search' && <><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></>}
              {f.icon === 'code' && <><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></>}
              {f.icon === 'image' && <><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></>}
              {f.icon === 'zap' && <><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></>}
              {f.icon === 'shield' && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></>}
              {f.icon === 'database' && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
              {f.icon === 'palette' && <><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 011.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></>}
              {f.icon === 'chart' && <><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></>}
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-sm text-surface-400 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
