---
// AdminConsoleLayout.astro - 어드민 콘솔 레이아웃
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="flex min-h-screen bg-surface-50">
    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-surface-200 fixed h-full overflow-y-auto shadow-light-md">
      <div class="p-6 border-b border-surface-200">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-danger-500 to-danger-600 flex items-center justify-center text-white font-bold text-lg">
            A
          </div>
          <div>
            <p class="font-bold text-surface-900">어드민</p>
            <p class="text-xs text-surface-500">관리자 콘솔</p>
          </div>
        </div>
      </div>

      <nav class="p-6 space-y-2">
        <a href="/admin" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-danger-50 text-surface-700 hover:text-danger-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-3m0 0l7-4 7 4M5 9v10a1 1 0 001 1h12a1 1 0 001-1V9m-9 16l4-4m0 0l4 4m-4-4v4" />
          </svg>
          <span>대시보드</span>
        </a>

        <a href="/admin/announcements" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-danger-50 text-surface-700 hover:text-danger-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.961 1.961 0 01-2.437-.458L3.546 13.914a2 2 0 000-2.828l5.017-5.318A1.961 1.961 0 0110.882 4.08M15 5.882v13.358a1.961 1.961 0 002.437.458l5.017-5.326a2 2 0 000-2.828l-5.017-5.318a1.961 1.961 0 00-2.437.458m0 0A1.97 1.97 0 0110 9.058v.165a1.97 1.97 0 002.437 1.911" />
          </svg>
          <span>공지사항</span>
        </a>

        <a href="/admin/users" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-danger-50 text-surface-700 hover:text-danger-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 8.048M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z" />
          </svg>
          <span>사용자 관리</span>
        </a>

        <a href="/admin/system" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-danger-50 text-surface-700 hover:text-danger-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          <span>시스템 통계</span>
        </a>

        <a href="/admin/settings" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-danger-50 text-surface-700 hover:text-danger-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>설정</span>
        </a>

        <hr class="my-4 border-surface-200" />

        <a href="/dashboard" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-surface-100 text-surface-700 hover:text-surface-900 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <span>일반 대시보드로 돌아가기</span>
        </a>

        <a href="/auth/logout" class="w-full flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-danger-50 text-surface-700 hover:text-danger-600 transition-colors text-left">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
          <span>로그아웃</span>
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="ml-64 flex-1">
      <!-- Top Bar -->
      <div class="bg-white border-b border-surface-200 shadow-light-md sticky top-0 z-40">
        <div class="px-8 py-4 flex justify-between items-center">
          <h1 class="text-2xl font-bold text-surface-900"><slot name="title" /></h1>
          <div class="flex items-center space-x-4">
            <button class="p-2 hover:bg-surface-100 rounded-lg transition-colors">
              <svg class="w-5 h-5 text-surface-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </button>
            <button class="w-10 h-10 rounded-full bg-gradient-to-br from-danger-400 to-danger-600 text-white flex items-center justify-center font-bold">
              A
            </button>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="p-8">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  aside::-webkit-scrollbar {
    width: 6px;
  }

  aside::-webkit-scrollbar-track {
    background: transparent;
  }

  aside::-webkit-scrollbar-thumb {
    background: #d1d5db;
    border-radius: 3px;
  }

  aside::-webkit-scrollbar-thumb:hover {
    background: #9ca3af;
  }
</style>
