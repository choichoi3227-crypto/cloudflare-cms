@@ -15,3 +15,12 @@ id = "e4858ee03ee4456989ca1cfcd3746a93"
 
 [vars]
 ENVIRONMENT = "production"
+# 이메일 인증 링크 생성 시 사용하는 프론트엔드 베이스 URL
