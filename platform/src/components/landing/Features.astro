---
// platform/src/components/landing/Features.astro
const features = [
  { icon:'wordpress', title:'진짜 워드프레스', desc:'PHP-WASM 런타임으로 실제 워드프레스 코어를 Edge에서 그대로 실행합니다. 익숙한 관리자 화면 그대로 사용하세요.' },
  { icon:'plugin', title:'플러그인·테마 호환', desc:'wp-admin에서 원하는 플러그인과 테마를 그대로 설치할 수 있습니다. 별도 마켓플레이스 제약이 없습니다.' },
  { icon:'migrate', title:'손쉬운 마이그레이션', desc:'기존 워드프레스 사이트를 데이터베이스, 미디어, 플러그인까지 그대로 가져올 수 있습니다.' },
  { icon:'lock', title:'보안 내장', desc:'CSP, XSS Protection, CSRF Protection과 관리자 다중 인증이 기본으로 적용됩니다.' },
  { icon:'zap', title:'Edge 캐싱', desc:'Cloudflare Edge에서 페이지를 캐싱하여 LCP 2초 이하, Lighthouse 95+를 달성합니다.' },
  { icon:'database', title:'서버리스 인프라', desc:'VPS 없이 Cloudflare Workers, D1, KV만으로 워드프레스를 운영합니다.' },
  { icon:'search', title:'SEO 최적화', desc:'sitemap.xml, robots.txt, Open Graph, 구조화 데이터가 기본 설정으로 제공됩니다.' },
  { icon:'domain', title:'커스텀 도메인', desc:'원하는 도메인을 연결하고 SSL 인증서를 자동으로 발급받으세요.' },
  { icon:'chart', title:'내장 분석', desc:'방문자, 페이지뷰, 검색 유입 통계를 별도 플러그인 없이 대시보드에서 확인합니다.' },
];
---
<section class="section-padding relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16"><h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">서버 관리 없이 <span class="gradient-text">워드프레스 그대로</span></h2><p class="text-lg text-surface-400 max-w-2xl mx-auto">플러그인, 테마, 관리자 화면은 그대로. 서버 세팅과 유지보수는 CloudPress가 대신합니다.</p></div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="group gradient-border rounded-xl p-6 card-hover bg-surface-900/50">
          <div class="w-12 h-12 rounded-xl bg-brand-500/10 flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
            <svg class="w-6 h-6 text-brand-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              {f.icon === 'wordpress' && <><circle cx="12" cy="12" r="10"/><path d="M8 9l2 8 2-5 2 5 2-8"/></>}
              {f.icon === 'plugin' && <><rect x="3" y="9" width="18" height="10" rx="2"/><path d="M8 9V6a2 2 0 012-2h4a2 2 0 012 2v3"/></>}
              {f.icon === 'migrate' && <><path d="M21 12a9 9 0 11-3.5-7.1"/><polyline points="21 4 21 9 16 9"/></>}
              {f.icon === 'lock' && <><rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 018 0v3"/></>}
              {f.icon === 'search' && <><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></>}
              {f.icon === 'zap' && <><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></>}
              {f.icon === 'database' && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
              {f.icon === 'domain' && <><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 010 20 15.3 15.3 0 010-20z"/></>}
              {f.icon === 'chart' && <><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></>}
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-sm text-surface-400 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
