---
// platform/src/pages/dashboard/index.astro
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { parseSessionCookie } from '../../lib/session';
import { apiClient } from '../../lib/api-client';
const session = parseSessionCookie(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/auth/login');
if (session.status === 'pending_cf_key') return Astro.redirect('/auth/complete-signup');
Astro.locals.user = { id: session.userId, email: session.email, username: session.username, avatar_url: session.avatarUrl };
const sitesResult = await apiClient.get<Array<{ id: string; site_name: string; domain: string; status: string; created_at: number }>>('/api/sites', Astro.request.headers.get('cookie'));
const sites = sitesResult.success ? (sitesResult.data ?? []) : [];
const statusBadgeClass: Record<string, string> = { active: 'badge-success', provisioning: 'badge-warning', suspended: 'badge-caution', deleted: 'badge-danger' };
const statusLabel: Record<string, string> = { active: '활성', provisioning: '준비 중', suspended: '일시 중지', deleted: '삭제됨' };
---
<DashboardLayout title="대시보드" activeNav="dashboard">
  <div class="mb-8"><h1 class="text-2xl font-bold text-white mb-2">대시보드</h1><p class="text-surface-400">환영합니다, {session.username}님.</p></div>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    <div class="glass rounded-xl p-6"><p class="text-sm text-surface-500 mb-1">사이트 수</p><p class="text-3xl font-bold text-white">{sites.length}</p></div>
    <div class="glass rounded-xl p-6"><p class="text-sm text-surface-500 mb-1">상태</p><p class="text-3xl font-bold text-green-400">정상</p></div>
  </div>
  <div class="flex items-center justify-between mb-4"><h2 class="text-lg font-semibold text-white">내 사이트</h2><a href="/dashboard/sites/create" class="btn-primary text-sm"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>사이트 만들기</a></div>
  {sites.length === 0 ? (
    <div class="glass rounded-xl p-12 text-center"><div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-surface-800 flex items-center justify-center"><svg class="w-8 h-8 text-surface-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg></div><h3 class="text-lg font-semibold text-white mb-2">아직 사이트가 없습니다</h3><p class="text-sm text-surface-500 mb-6">첫 사이트를 만들어보세요.</p><a href="/dashboard/sites/create" class="btn-primary text-sm">사이트 만들기</a></div>
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">{sites.map((s) => (
      <a href={`https://${s.domain}/cp-admin/`} class="glass rounded-xl p-6 card-hover block group">
        <div class="flex items-start justify-between mb-3"><div><h3 class="text-lg font-semibold text-white group-hover:text-brand-500 transition-colors">{s.site_name}</h3><p class="text-sm text-surface-500">{s.domain}</p></div><span class:list={['badge', statusBadgeClass[s.status] || 'badge-neutral']}>{statusLabel[s.status] || s.status}</span></div>
        <div class="flex items-center gap-2 text-sm text-surface-500"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>{new Date(s.created_at * 1000).toLocaleDateString('ko-KR')}</div>
      </a>
    ))}</div>
  )}
</DashboardLayout>
