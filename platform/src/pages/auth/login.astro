---
// platform/src/pages/auth/login.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { parseSessionCookie } from '../../lib/session';

// 이미 로그인된 사용자는 대시보드로 즉시 이동합니다.
const session = parseSessionCookie(Astro.request.headers.get('cookie'));
if (session) return Astro.redirect('/dashboard');

const errorParam = Astro.url.searchParams.get('error');
const errorMessages: Record<string, string> = {
  no_code: 'Cloudflare 인증 코드를 받지 못했습니다. 다시 시도해주세요.',
  auth_failed: 'Cloudflare 로그인에 실패했습니다. 다시 시도해주세요.',
};
const errorMessage = errorParam ? (errorMessages[errorParam] || '로그인 중 오류가 발생했습니다. 다시 시도해주세요.') : null;
---
<BaseLayout title="로그인 - CloudPress" description="Cloudflare 계정으로 CloudPress에 로그인하세요." noIndex={true}>
  <section class="section-padding">
    <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass rounded-2xl p-8 text-center">
        <div class="w-14 h-14 mx-auto mb-6 bg-brand-500 rounded-2xl flex items-center justify-center">
          <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h1 class="text-2xl font-bold text-white mb-2">CloudPress 로그인</h1>
        <p class="text-sm text-surface-400 mb-8">Cloudflare 계정으로 안전하게 로그인하세요. 별도의 회원가입이나 비밀번호가 필요하지 않습니다.</p>

        {errorMessage && (
          <div class="alert-error mb-6 text-left">{errorMessage}</div>
        )}

        <a href="/api/auth/login" id="cf-login-btn" class="btn-primary w-full">
          <svg class="w-5 h-5" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M25.3 16.6c-.1-4-3.3-7.2-7.3-7.2-3 0-5.6 1.8-6.7 4.4-.4-.2-.9-.3-1.4-.3-1.8 0-3.3 1.4-3.4 3.2C4.6 17.1 3 18.8 3 20.9 3 23.2 4.8 25 7.1 25h17.6c2 0 3.6-1.6 3.6-3.6.1-2-1.4-3.7-3-4.8z"/></svg>
          Cloudflare 계정으로 로그인
        </a>

        <p class="text-xs text-surface-600 mt-6">로그인 시 CloudPress의 <a href="/이용약관" class="underline hover:text-surface-400">이용약관</a> 및 <a href="/개인정보처리방침" class="underline hover:text-surface-400">개인정보처리방침</a>에 동의하는 것으로 간주됩니다.</p>
      </div>
    </div>
  </section>
</BaseLayout>
<script>
  // JS가 활성화된 경우 버튼 텍스트가 잠깐 로딩 상태로 바뀌도록 처리 (링크 자체는 서버에서 리다이렉트 처리)
  const btn = document.getElementById('cf-login-btn');
  btn?.addEventListener('click', () => {
    btn.classList.add('opacity-70', 'pointer-events-none');
  });
</script>
