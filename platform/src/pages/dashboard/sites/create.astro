---
// platform/src/pages/dashboard/sites/create.astro
import DashboardLayout from '@layouts/DashboardLayout.astro';
// 인증/세션 검증은 src/middleware.ts에서 전역으로 처리됩니다.
---
<DashboardLayout title="사이트 만들기" activeNav="sites">
  <div class="mb-8"><a href="/dashboard" class="text-sm text-surface-500 hover:text-surface-700 mb-2 inline-flex items-center gap-1"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"/></svg>대시보드</a><h1 class="text-2xl font-bold text-surface-900">새 사이트 만들기</h1></div>
  <form id="create-site-form" class="glass rounded-xl p-8 max-w-lg">
    <div class="space-y-6">
      <div><label for="siteName" class="block text-sm font-medium text-surface-700 mb-2">사이트 이름 <span class="text-brand-500">*</span></label><input type="text" id="siteName" name="siteName" required minlength="2" maxlength="50" placeholder="예: 내 블로그" class="input-field" autocomplete="off"/></div>
      <div><label for="domain" class="block text-sm font-medium text-surface-700 mb-2">도메인 <span class="text-brand-500">*</span></label><input type="text" id="domain" name="domain" required placeholder="예: blog.example.com" class="input-field" autocomplete="off"/><p class="text-xs text-surface-500 mt-1">Cloudflare에 등록된 도메인을 입력하세요.</p></div>
      <div id="error-message" class="hidden p-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-600"></div>
      <button type="submit" id="submit-btn" class="btn-primary w-full">사이트 만들기</button>
    </div>
  </form>
  <script>
    const form = document.getElementById('create-site-form') as HTMLFormElement;
    const errorEl = document.getElementById('error-message') as HTMLDivElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault(); errorEl.classList.add('hidden'); submitBtn.disabled = true; submitBtn.textContent = '생성 중...';
      const siteName = (document.getElementById('siteName') as HTMLInputElement).value.trim();
      const domain = (document.getElementById('domain') as HTMLInputElement).value.trim();
      try {
        const r = await fetch('/api/sites', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({site_name:siteName,domain}) });
        const result = await r.json();
        if (result.success) { window.location.href = '/dashboard'; }
        else { errorEl.textContent = result.error?.message || '사이트 생성에 실패했습니다.'; errorEl.classList.remove('hidden'); submitBtn.disabled = false; submitBtn.textContent = '사이트 만들기'; }
      } catch { errorEl.textContent = '네트워크 오류가 발생했습니다.'; errorEl.classList.remove('hidden'); submitBtn.disabled = false; submitBtn.textContent = '사이트 만들기'; }
    });
  </script>
</DashboardLayout>
