---
// 콘솔 대시보드
// 경로: /console
import ConsoleLayout from '@layouts/ConsoleLayout.astro';

// 데모 데이터
const metrics = {
  hostings: 5,
  domains: 3,
  storage: {
    used: 45.2,
    total: 100,
  },
  traffic: {
    current: 1234,
    limit: 10000,
  },
};

const recentActivities = [
  {
    id: 1,
    title: 'blog.example.com 생성됨',
    time: '2시간 전',
    icon: 'plus',
  },
  {
    id: 2,
    title: '스토리지 업그레이드 완료',
    time: '1일 전',
    icon: 'check',
  },
  {
    id: 3,
    title: 'example.com DNS 설정 변경',
    time: '3일 전',
    icon: 'edit',
  },
  {
    id: 4,
    title: 'WordPress 플러그인 업데이트',
    time: '1주일 전',
    icon: 'refresh',
  },
];

const storagePercentage = (metrics.storage.used / metrics.storage.total) * 100;
const trafficPercentage = (metrics.traffic.current / metrics.traffic.limit) * 100;
---

<ConsoleLayout>
  <div class="p-8 space-y-8">
    <!-- 페이지 제목 -->
    <div>
      <h1 class="text-4xl font-bold text-surface-900 mb-2">대시보드</h1>
      <p class="text-surface-600">호스팅, 도메인, 스토리지 현황을 한눈에 확인하세요</p>
    </div>

    <!-- 메트릭 카드 -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <!-- 호스팅 수 -->
      <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-primary-500">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-sm font-semibold text-surface-600 mb-1">활성 호스팅</p>
            <p class="text-3xl font-bold text-primary-600">{metrics.hostings}</p>
            <p class="text-xs text-surface-500 mt-2">WordPress 인스턴스</p>
          </div>
          <svg class="w-10 h-10 text-primary-100" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2zm0 2c-4.418 0-8 3.582-8 8s3.582 8 8 8 8-3.582 8-8-3.582-8-8-8zm-1 4h2v4h-2V8zm0 6h2v2h-2v-2z" />
          </svg>
        </div>
        <a href="/console/hosting" class="text-primary-600 hover:text-primary-700 text-sm font-semibold mt-4 inline-flex items-center space-x-1">
          <span>관리</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- 도메인 수 -->
      <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-success-500">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-sm font-semibold text-surface-600 mb-1">등록 도메인</p>
            <p class="text-3xl font-bold text-success-600">{metrics.domains}</p>
            <p class="text-xs text-surface-500 mt-2">연결된 도메인</p>
          </div>
          <svg class="w-10 h-10 text-success-100" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z" />
          </svg>
        </div>
        <a href="/console/domains" class="text-success-600 hover:text-success-700 text-sm font-semibold mt-4 inline-flex items-center space-x-1">
          <span>관리</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- 스토리지 사용량 -->
      <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-warning-500">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-sm font-semibold text-surface-600 mb-1">스토리지</p>
            <p class="text-3xl font-bold text-warning-600">{metrics.storage.used.toFixed(1)}GB</p>
            <p class="text-xs text-surface-500 mt-2">/{metrics.storage.total}GB 사용</p>
          </div>
          <svg class="w-10 h-10 text-warning-100" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
          </svg>
        </div>
        <div class="w-full bg-surface-200 rounded-full h-2 mt-4">
          <div class="bg-warning-500 h-2 rounded-full" style={`width: ${storagePercentage}%`}></div>
        </div>
      </div>

      <!-- 트래픽 -->
      <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-info-500">
        <div class="flex items-start justify-between">
          <div>
            <p class="text-sm font-semibold text-surface-600 mb-1">트래픽 (이번 달)</p>
            <p class="text-3xl font-bold text-info-600">{metrics.traffic.current.toLocaleString()}</p>
            <p class="text-xs text-surface-500 mt-2">/{metrics.traffic.limit.toLocaleString()} 요청</p>
          </div>
          <svg class="w-10 h-10 text-info-100" fill="currentColor" viewBox="0 0 24 24">
            <path d="M3 13h2v8H3zm4-8h2v16H7zm4-2h2v18h-2zm4-1h2v19h-2zm4 4h2v15h-2z" />
          </svg>
        </div>
        <div class="w-full bg-surface-200 rounded-full h-2 mt-4">
          <div class="bg-info-500 h-2 rounded-full" style={`width: ${Math.min(trafficPercentage, 100)}%`}></div>
        </div>
      </div>
    </div>

    <!-- 최근 활동 -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-md p-6">
          <h2 class="text-xl font-bold text-surface-900 mb-6">최근 활동</h2>
          <div class="space-y-4">
            {recentActivities.map((activity) => (
              <div class="flex items-start space-x-4 p-4 hover:bg-surface-50 rounded-lg transition-colors">
                <div
                  class={`w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 ${
                    activity.icon === 'plus'
                      ? 'bg-success-100'
                      : activity.icon === 'check'
                        ? 'bg-primary-100'
                        : activity.icon === 'edit'
                          ? 'bg-info-100'
                          : 'bg-warning-100'
                  }`}
                >
                  {activity.icon === 'plus' && (
                    <svg class="w-5 h-5 text-success-600" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                    </svg>
                  )}
                  {activity.icon === 'check' && (
                    <svg class="w-5 h-5 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                    </svg>
                  )}
                  {activity.icon === 'edit' && (
                    <svg class="w-5 h-5 text-info-600" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z" />
                    </svg>
                  )}
                  {activity.icon === 'refresh' && (
                    <svg class="w-5 h-5 text-warning-600" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M1 4v6h6M23 20v-6h-6" />
                    </svg>
                  )}
                </div>
                <div class="flex-1">
                  <p class="font-semibold text-surface-900">{activity.title}</p>
                  <p class="text-sm text-surface-500">{activity.time}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- 빠른 작업 -->
      <div class="bg-white rounded-xl shadow-md p-6">
        <h2 class="text-xl font-bold text-surface-900 mb-6">빠른 작업</h2>
        <div class="space-y-3">
          <a href="/console/hosting" class="flex items-center space-x-3 p-3 bg-primary-50 hover:bg-primary-100 rounded-lg transition-colors text-primary-600 hover:text-primary-700 font-semibold">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
            </svg>
            <span>호스팅 추가</span>
          </a>
          <a href="/console/domains/add" class="flex items-center space-x-3 p-3 bg-success-50 hover:bg-success-100 rounded-lg transition-colors text-success-600 hover:text-success-700 font-semibold">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
            </svg>
            <span>도메인 추가</span>
          </a>
          <a href="/console/storage" class="flex items-center space-x-3 p-3 bg-warning-50 hover:bg-warning-100 rounded-lg transition-colors text-warning-600 hover:text-warning-700 font-semibold">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
            </svg>
            <span>스토리지 보기</span>
          </a>
          <a href="/console/settings" class="flex items-center space-x-3 p-3 bg-surface-100 hover:bg-surface-200 rounded-lg transition-colors text-surface-600 hover:text-surface-700 font-semibold">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            </svg>
            <span>설정</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</ConsoleLayout>
