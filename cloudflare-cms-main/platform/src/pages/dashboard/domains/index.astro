---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import { parseSessionCookie } from '@lib/session';
const session = parseSessionCookie(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/auth/login');
Astro.locals.user = { id: session.userId, email: session.email, username: session.username, avatar_url: session.avatarUrl };
const domains = [
  { name: 'example.com', zone: 'Cloudflare 연결됨', cdn: '활성', dnsUrl: 'https://dash.cloudflare.com/?to=/:account/:zone/dns' },
  { name: 'blog.example.com', zone: 'Route 대기', cdn: '준비 중', dnsUrl: 'https://dash.cloudflare.com/?to=/:account/:zone/dns' },
];
---
<DashboardLayout title="도메인/DNS 관리" activeNav="domains">
  <div class="mb-8"><h1 class="text-2xl font-bold text-white mb-2">도메인 관리</h1><p class="text-surface-400">Cloudflare 계정 기반으로 연결 도메인, DNS, CDN 상태를 관리합니다.</p></div>
  <div class="glass rounded-xl overflow-hidden"><table class="w-full text-sm"><thead class="bg-surface-800"><tr><th class="text-left p-4 text-surface-400">도메인</th><th class="text-left p-4 text-surface-400">Zone</th><th class="text-left p-4 text-surface-400">CDN</th><th class="text-right p-4 text-surface-400">작업</th></tr></thead><tbody>{domains.map((domain) => <tr class="border-t border-surface-800"><td class="p-4 font-medium text-white">{domain.name}</td><td class="p-4 text-surface-400">{domain.zone}</td><td class="p-4 text-surface-400">{domain.cdn}</td><td class="p-4 text-right"><a href={domain.dnsUrl} target="_blank" rel="noreferrer" class="btn-secondary text-xs">DNS 관리</a></td></tr>)}</tbody></table></div>
  <div class="mt-6 glass rounded-xl p-6"><h2 class="text-lg font-semibold text-white mb-2">자동화 규칙</h2><p class="text-sm text-surface-400">DNS 관리 버튼은 Cloudflare Dashboard DNS 화면으로 이동하며, API 연결 후 실제 account/zone 값으로 치환됩니다.</p></div>
</DashboardLayout>
