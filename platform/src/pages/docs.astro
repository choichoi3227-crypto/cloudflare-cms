---
// platform/src/pages/docs.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const guideSections = [
  {
    title: '시작하기',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    items: [
      { title: 'CloudPress란?', desc: 'Cloudflare Workers 위에서 동작하는 WordPress 호스팅/AI CMS 플랫폼 개요' },
      { title: 'Cloudflare 계정으로 로그인', desc: 'OAuth 기반 로그인 방식과 필요한 계정 권한 안내' },
      { title: '첫 사이트 만들기', desc: '사이트 이름과 도메인을 입력해 몇 분 안에 WordPress 사이트를 생성하는 방법' },
    ],
  },
  {
    title: '호스팅 & 인프라',
    icon: 'M4 7a2 2 0 012-2h12a2 2 0 012 2v3H4V7zm0 7h16v3a2 2 0 01-2 2H6a2 2 0 01-2-2v-3z',
    items: [
      { title: '단일 Worker 호스팅 구조', desc: '모든 사이트가 하나의 공용 Worker에서 라우팅되는 방식과 이유' },
      { title: 'PHP-WASM 런타임', desc: 'WordPress PHP 코드가 Edge에서 WASM으로 실행되는 원리' },
      { title: 'SQLite Shard 구조', desc: 'D1 기반 자동 확장 shard(database01.db~)와 트래픽 분산 방식' },
      { title: '도메인 & DNS 연결', desc: 'Cloudflare Zone에 도메인을 연결하고 라우팅 규칙을 등록하는 방법' },
    ],
  },
  {
    title: 'CDN & 캐시',
    icon: 'M3 15a4 4 0 014-4h1a5 5 0 019.8-1.2A3.5 3.5 0 1120 16H7a4 4 0 01-4-1z',
    items: [
      { title: 'WP Rocket 캐시 레이어', desc: 'HTML/에셋 캐시 정책과 캐시 무효화(Purge) 방법' },
      { title: 'Cloudflare Cache Rules', desc: '도메인별 캐시 규칙, Page Rules와의 관계' },
      { title: '이미지 최적화', desc: 'AI 이미지 생성 Worker와 반응형 srcset 자동 생성' },
    ],
  },
  {
    title: '마이그레이션',
    icon: 'M4 4v6h6M20 20v-6h-6M20 9A8 8 0 006.7 5.1L4 10m16 4l-2.7 4.9A8 8 0 014 15',
    items: [
      { title: '기존 WordPress에서 이전하기', desc: 'CloudPress Easy Migration 플러그인으로 ZIP 내보내기/가져오기' },
      { title: '대용량 사이트 복원', desc: 'Workflow 기반 배치 복원으로 대량 업로드 오류를 방지하는 방법' },
    ],
  },
  {
    title: 'AI 기능',
    icon: 'M12 2l2.4 7.2H22l-6 4.6 2.3 7.2L12 16.4 5.7 21l2.3-7.2-6-4.6h7.6z',
    items: [
      { title: 'AI 글쓰기', desc: '6가지 유형의 AI 콘텐츠 생성 기능 사용법' },
      { title: 'AI SEO 분석', desc: 'Meta, Title, Readability 등 SEO 점수를 자동으로 분석하는 방법' },
      { title: 'AI 이미지 생성', desc: '프롬프트 기반 썸네일/본문 이미지 자동 생성' },
    ],
  },
  {
    title: 'API 레퍼런스',
    icon: 'M8 9l-4 3 4 3m8-6l4 3-4 3M14 4l-4 16',
    items: [
      { title: '인증', desc: 'Cloudflare OAuth 세션과 API 요청 시 필요한 헤더' },
      { title: '사이트 API', desc: 'GET/POST /api/sites, GET/DELETE /api/sites/:id 명세' },
      { title: '오류 응답 형식', desc: '모든 API가 공통으로 사용하는 { success, error } 응답 스펙' },
    ],
  },
];
---
<BaseLayout title="문서 - CloudPress" description="CloudPress 사용 가이드와 API 레퍼런스를 확인하세요.">
  <section class="section-padding">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-bold text-white mb-4">문서</h1>
        <p class="text-lg text-surface-400">CloudPress를 시작하는 방법부터 API 레퍼런스까지 한 곳에서 확인하세요.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {guideSections.map((section) => (
          <div class="glass rounded-xl p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-brand-500/10 flex items-center justify-center text-brand-500">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={section.icon}/></svg>
              </div>
              <h2 class="text-lg font-semibold text-white">{section.title}</h2>
            </div>
            <ul class="space-y-3">
              {section.items.map((item) => (
                <li class="pl-3 border-l-2 border-surface-800">
                  <p class="text-sm font-medium text-surface-200">{item.title}</p>
                  <p class="text-xs text-surface-500 mt-0.5">{item.desc}</p>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="mt-12 glass rounded-xl p-8 text-center">
        <h2 class="text-xl font-semibold text-white mb-2">더 궁금한 점이 있으신가요?</h2>
        <p class="text-sm text-surface-400 mb-6">대시보드에서 직접 사이트를 만들어보거나, 기능 페이지에서 전체 기능 목록을 확인하세요.</p>
        <div class="flex items-center justify-center gap-3">
          <a href="/dashboard" class="btn-primary text-sm">대시보드로 이동</a>
          <a href="/features" class="btn-secondary text-sm">전체 기능 보기</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
