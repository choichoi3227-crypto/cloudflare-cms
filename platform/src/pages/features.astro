---
// platform/src/pages/features.astro
import BaseLayout from '@layouts/BaseLayout.astro';
const sections = [
  { title:'워드프레스 코어', items:['PHP-WASM 런타임','플러그인 설치 지원','테마 설치 지원','wp-admin 관리자 화면','Gutenberg 블록 에디터','댓글 시스템','카테고리·태그','메뉴 관리','RSS 피드','예약 발행','다중 관리자 계정','권한(역할) 관리'] },
  { title:'마이그레이션 & 백업', items:['기존 워드프레스 가져오기','데이터베이스 마이그레이션','미디어 파일 이전','플러그인·테마 이전','전체 백업','부분 백업(콘텐츠/DB)','GitHub Releases 기반 저장'] },
  { title:'SEO', items:['sitemap.xml 자동 생성','robots.txt 관리','Canonical URL','Open Graph','Twitter Card','구조화 데이터(JSON-LD)','메타 설명 관리','리디렉션 관리'] },
  { title:'인프라 & 성능', items:['Cloudflare Workers','Cloudflare D1','Cloudflare KV','Edge 캐싱','HTML/CSS/JS Minify','이미지 최적화','커스텀 도메인 연결','SSL 자동 발급','Lighthouse 95+'] },
];
---
<BaseLayout title="기능 - CloudPress" description="Cloudflare 기반 워드프레스 호스팅, CloudPress의 모든 기능을 살펴보세요.">
  <section class="section-padding">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-white mb-4 text-center">모든 기능</h1>
      <p class="text-lg text-surface-400 text-center mb-16">서버 관리 없이 진짜 워드프레스를 운영하는 데 필요한 모든 기능입니다.</p>
      <div class="flex justify-center mb-16">
        <img src="/images/wh-device.avif" alt="다양한 기기에서 접속 가능한 워드프레스 호스팅" class="w-40 h-40" width="160" height="160" loading="lazy" />
      </div>
      <div class="space-y-12">
        {sections.map((s) => (
          <div class="glass rounded-xl p-8">
            <h2 class="text-2xl font-bold text-white mb-4">{s.title}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">{s.items.map((item) => (
              <div class="flex items-center gap-2 text-surface-300"><svg class="w-4 h-4 text-brand-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>{item}</div>
            ))}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
